# ── Required ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Optional ───────────────────────────────────────────────────────────────────
# Storage paths (default to /tmp if not set)
UPLOADS_DIR=/tmp/ai_analyst_uploads
OUTPUTS_DIR=/tmp/ai_analyst_outputs

# Max file size in MB
MAX_FILE_SIZE_MB=50

# Streamlit → API URL
API_BASE_URL=http://localhost:8000/api/v1

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
